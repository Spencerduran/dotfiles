[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[user]
	name = Spencer Duran
	email = spencerduran@gmail.com
[push]
	default = simple
[core]
	excludesfile = /Users/spencerduran/.gitignore_global
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential

[includeIf "gitdir:~/repos/MLG/"]
	path = ~/.gitconfig-mlg
