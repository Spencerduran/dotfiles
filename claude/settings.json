{
  "env": {
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf --max-time 2 http://localhost:8181/health >/dev/null 2>&1 || qmd mcp --http --daemon; qmd update --quiet"
          },
          {
            "type": "command",
            "command": "if git rev-parse --git-dir >/dev/null 2>&1 && gitnexus status 2>/dev/null | grep -q 'not indexed'; then echo 'GitNexus: repo not indexed — run gitnexus analyze to enable code graph features'; fi",
            "statusMessage": "Checking GitNexus index..."
          },
          {
            "type": "command",
            "command": "if git rev-parse --git-dir >/dev/null 2>&1 && ! [ -f \"$(git rev-parse --show-toplevel)/.understand-anything/knowledge-graph.json\" ]; then echo 'Understand-Anything: not analyzed — run /understand to build knowledge graph'; fi",
            "statusMessage": "Checking Understand-Anything index..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/plugins/marketplaces/personal-os-skills/skills/sync-claude-sessions/scripts/claude-sessions sync",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "VAULT_DIR=$HOME/vaults/claude_memory python3 ~/.claude/plugins/marketplaces/personal-os-skills/skills/sync-claude-sessions/scripts/claude-sessions sync",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/index-sessions.sh >> ~/.claude/hooks/index-sessions.log 2>&1",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/index-sessions.sh >> ~/.claude/hooks/index-sessions.log 2>&1",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/stop-slop-reminder.sh",
            "statusMessage": "Checking prose quality..."
          }
        ]
      },
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"/Users/spencerduran/.claude/hooks/gitnexus/gitnexus-hook.cjs\"",
            "timeout": 10,
            "statusMessage": "Enriching with GitNexus graph context..."
          }
        ]
      }
    ],
    "PostToolUse": [],
    "PostToolUseFailure": []
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'cols=$(stty size </dev/tty 2>/dev/null | awk '\"'\"'{print $2}'\"'\"'); export COLUMNS=$(( ${cols:-120} > 4 ? ${cols:-120} - 4 : 1 )); plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/*/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | grep -E '\"'\"'^[0-9]+\\.[0-9]+\\.[0-9]+[[:space:]]'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/opt/homebrew/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "qmd@qmd": false,
    "tasknotes-skill@personal-os-skills": true,
    "wispr-flow-skill@personal-os-skills": false,
    "recall-skill@personal-os-skills": true,
    "sync-claude-sessions-skill@personal-os-skills": true,
    "superpowers@claude-plugins-official": true,
    "obsidian@obsidian-skills": true,
    "claude-mem@thedotmack": true,
    "atlassian@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "arscontexta@agenticnotetaking": true,
    "claude-hud@claude-hud": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "qmd": {
      "source": {
        "source": "github",
        "repo": "tobi/qmd"
      }
    },
    "personal-os-skills": {
      "source": {
        "source": "github",
        "repo": "spencerduran/personal-os-skills"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "obsidian-skills": {
      "source": {
        "source": "github",
        "repo": "kepano/obsidian-skills"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "claude-sound-fx": {
      "source": {
        "source": "github",
        "repo": "6m1w/claude-sound-fx"
      }
    },
    "agenticnotetaking": {
      "source": {
        "source": "github",
        "repo": "agenticnotetaking/arscontexta"
      }
    },
    "jarrodwatts": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
